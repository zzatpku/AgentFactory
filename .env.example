# Model Selection (OPENAI_STYLE or ANTHROPIC_STYLE)
MODEL_PROTOCOL=OPENAI_STYLE

# Claude API Configuration
LLM_URL_CLAUDE=<Your LLM API URL Here>
LLM_API_KEY_CLAUDE=<Your LLM API Key Here>
LLM_MODEL_CLAUDE=claude-opus-4-6

# MiniMax API Configuration
LLM_URL_MINIMAX=<Your LLM API URL Here>
LLM_API_KEY_MINIMAX=<Your LLM API Key Here>
LLM_MODEL_MINIMAX=MiniMax-M2.7

# Tool API Keys
SERPER_API_KEY=<Your Serper API Key Here>
JINA_API_KEY=<Your Jina API Key Here>
